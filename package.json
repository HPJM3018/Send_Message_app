{
  "name": "express-js",
  "version": "1.0.0",
  "description": "Express app with messages",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "test": "NODE_ENV=test jest --coverage --runInBand --forceExit",   
    "test:watch": "jest --watch",
    "test:clean": "rm -f db/express_test.db && npm test",
    "test:setup": "mkdir -p db && touch db/express_test.db",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "vercel-build": "npm ci --production"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "moment": "^2.30.1",
    "nodemon": "^3.1.14",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "forceExit": true,
    "testTimeout" : 30000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "server.js",
      "models/*.js",
      "middlewares/*.js",
      "!**/node_modules/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": "20.x"
  }
}